<?xml version="1.0"?>
<!-- Simple water bottle: cylinder, r=0.035m, h=0.25m, origin at base -->
<robot name="water_bottle">
  <link name="bottle_base"/>
  <joint name="bottle_base_joint" type="fixed">
    <parent link="bottle_base"/>
    <child link="bottle_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="bottle_link">
    <visual>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.25"/>
      </geometry>
      <material name="bottle_green">
        <color rgba="0.15 0.65 0.25 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.25"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.125" rpy="0 0 0"/>
      <mass value="0.5"/>
      <!-- Cylinder inertia: m=0.5, r=0.035, h=0.25 -->
      <!-- Ixx = Iyy = m*(3r^2+h^2)/12 = 0.5*(3*0.001225+0.0625)/12 ≈ 0.00267 -->
      <!-- Izz = m*r^2/2 = 0.5*0.001225/2 ≈ 0.000306 -->
      <inertia ixx="0.00267" ixy="0" ixz="0"
               iyy="0.00267" iyz="0"
               izz="0.000306"/>
    </inertial>
  </link>
</robot>
